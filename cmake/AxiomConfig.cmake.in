@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Bundled static dependencies linked privately into axiom. They are exported
# alongside axiom, so consumers must be able to resolve their imported targets
# (hwy::hwy, mimalloc-static) referenced by AxiomTargets.cmake.
find_dependency(hwy)
if(@AXIOM_HAS_MIMALLOC@)
    find_dependency(mimalloc)
endif()

# Find platform-specific dependencies
# Metal/Foundation are only needed when the library was built with Metal support
if(APPLE)
    find_library(_axiom_metal_fw Metal QUIET)
    find_library(_axiom_foundation_fw Foundation QUIET)
    if(NOT _axiom_metal_fw OR NOT _axiom_foundation_fw)
        message(STATUS "Axiom: Metal/Foundation frameworks not found — GPU support unavailable")
    endif()
endif()

# Include the targets file
include("${CMAKE_CURRENT_LIST_DIR}/AxiomTargets.cmake")

# Check that all required components are available
check_required_components(Axiom)